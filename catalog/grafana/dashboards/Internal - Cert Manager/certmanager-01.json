{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations y Alertas",
        "type": "dashboard"
      }
    ]
  },
  "description": "Dashboard base de cert-manager para operacion diaria: estado de certificados, vencimientos y errores de emision/renovacion.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": 0,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cantidad de certificados no listos en ventana de 5 minutos.\nUso operacional: si este valor es mayor a 0, hay certificados que no estan en condicion de servir trafico TLS y debe revisarse el recurso Certificate/Challenge asociado.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(\n  max_over_time(\n    certmanager_certificate_ready_status{\n      job=~\"$job\",\n      exported_namespace=~\"$namespace\",\n      condition!=\"True\"\n    }[5m]\n  )\n) or vector(0)",
          "hide": false,
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Certificados no listos",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cantidad de certificados que vencen en los proximos 7 dias.\nUso operacional: sirve para priorizar renovaciones antes del incidente. Si sube, revisar Issuer/ClusterIssuer y flujo ACME.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(((certmanager_certificate_expiration_timestamp_seconds{job=~\"$job\", exported_namespace=~\"$namespace\"} - time()) < bool 604800) * ((certmanager_certificate_expiration_timestamp_seconds{job=~\"$job\", exported_namespace=~\"$namespace\"} - time()) > bool 0))",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Vencen en < 7 dias",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cantidad de certificados ya vencidos.\nUso operacional: este valor debe ser 0. Si es mayor a 0, existe riesgo o impacto directo de TLS en aplicaciones.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "sum(certmanager_certificate_expiration_timestamp_seconds{job=~\"$job\", exported_namespace=~\"$namespace\"} < bool time())",
          "refId": "A"
        }
      ],
      "title": "Certificados vencidos",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Tasa de respuestas HTTP 429 de ACME (rate limiting).\nUso operacional: si aparece > 0, cert-manager esta siendo limitado por el proveedor ACME y pueden fallar renovaciones/emisiones.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "sum(rate(certmanager_http_acme_client_request_count{job=~\"$job\", status=\"429\"}[$__rate_interval])) or sum(rate(certmanager_acme_client_request_count{job=~\"$job\", status=\"429\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "title": "ACME 429/s",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Dias restantes hasta vencimiento por certificado.\nUso operacional: detectar rapidamente certificados cercanos a vencerse y priorizar revisiones por namespace/aplicacion.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "d"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "asc"
        }
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "(certmanager_certificate_expiration_timestamp_seconds{job=~\"$job\", exported_namespace=~\"$namespace\"} - time()) / 86400",
          "legendFormat": "{{exported_namespace}}/{{name}}",
          "refId": "A"
        }
      ],
      "title": "Dias hasta vencimiento",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Top de certificados mas proximos a vencer.\nUso operacional: lista de trabajo priorizada para validar issuer, challenge y estado de renovacion antes de expiracion.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "footer": {
              "reducers": []
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "d"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "certificado"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 266
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": []
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "bottomk(20, clamp_min((certmanager_certificate_expiration_timestamp_seconds{job=~\"$job\", exported_namespace=~\"$namespace\"} - time()) / 86400, 0))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Top certificados proximos a vencer",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "account": true,
              "container": true,
              "endpoint": true,
              "environment": true,
              "instance": true,
              "job": true,
              "namespace": true,
              "pod": true,
              "prometheus": true,
              "prometheus_replica": true,
              "region": true,
              "service": true
            },
            "includeByName": {},
            "indexByName": {
              "Value": 3,
              "exported_namespace": 0,
              "issuer_name": 2,
              "name": 1
            },
            "renameByName": {
              "Value": "dias_restantes",
              "exported_namespace": "namespace",
              "issuer_name": "issuer",
              "name": "certificado"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Errores por controlador durante sync().\nUso operacional: identifica que controlador de cert-manager esta fallando (orders, challenges, certificates, etc.) y acelera troubleshooting.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "sum by (controller) (rate(certmanager_controller_sync_error_count{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "title": "Errores de sync por controlador",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Trafico ACME por status HTTP.\nUso operacional: permite ver si las renovaciones/emisiones avanzan con 2xx o si empiezan a predominar 4xx/5xx.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 0,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 8,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "sum by (status) (rate(certmanager_http_acme_client_request_count{job=~\"$job\"}[$__rate_interval])) or sum by (status) (rate(certmanager_acme_client_request_count{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Requests ACME por status",
      "type": "timeseries"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "cert-manager",
    "tls",
    "certificates"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "Internal Mimir",
          "value": "prometheus"
        },
        "includeAll": false,
        "label": "Metrica",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(certmanager_certificate_ready_status, exported_namespace)",
        "includeAll": true,
        "label": "Namespace certificado",
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": {
          "query": "label_values(certmanager_certificate_ready_status, exported_namespace)",
          "refId": "A"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "text": [
            "cert-manager"
          ],
          "value": [
            "cert-manager"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(certmanager_certificate_ready_status, job)",
        "includeAll": true,
        "label": "Job",
        "multi": true,
        "name": "job",
        "options": [],
        "query": {
          "query": "label_values(certmanager_certificate_ready_status, job)",
          "refId": "A"
        },
        "refresh": 1,
        "regex": "cert-manager|certmanager",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Cert-Manager / Base Operacional",
  "uid": "platform-certmanager-base-operacional",
  "version": 4
}
