          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "$datasource"
          },
          "expr": "sum(rate(argocd_app_reconcile_sum{namespace=~\"$namespace\"}[5m])) / sum(rate(argocd_app_reconcile_count{namespace=~\"$namespace\"}[5m]))",
          "format": "time_series",
          "refId": "A",
          "legendFormat": "avg"
        }
      ],
      "title": "Reconciliation Avg Duration",
      "type": "timeseries"
