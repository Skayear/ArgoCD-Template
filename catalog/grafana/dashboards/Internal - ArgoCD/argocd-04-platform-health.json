      "title": "Carga del controller",
      "type": "row"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 56,
      "options": {
        "dataLinks": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "$datasource"
          },
          "expr": "sum(round(increase(argocd_app_sync_total{namespace=~\"$namespace\",dest_server=~\"$cluster\"}[$interval]))) by ($grouping)",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{$grouping}}",
          "refId": "A"
        }
      ],
      "title": "Sync Activity",
      "type": "timeseries",
      "description": "Cantidad de syncs ejecutados en el intervalo. Sirve para ver volumen operativo; picos indican despliegues masivos o mucha actividad GitOps."
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 58,
      "options": {
        "dataLinks": []
      },
      "targets": [
        {
          "datasource": {
            "uid": "$datasource"
          },
          "expr": "sum(increase(argocd_app_reconcile_count{namespace=~\"$namespace\",dest_server=~\"$cluster\"}[$interval])) by ($grouping)",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{$grouping}}",
          "refId": "A"
        }
      ],
      "title": "Reconciliation Activity",
      "type": "timeseries",
      "description": "Cantidad de reconciliaciones. Reconciliar significa comparar Git contra el cluster. Picos sostenidos pueden indicar drift frecuente, loops o mucho cambio."
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "description": "Duracion promedio de reconciliacion en segundos. Mas simple que el heatmap: si sube sostenidamente, ArgoCD tarda mas en comparar Git contra el cluster.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "auto",
            "scaleDistribution": {
              "type": "linear"
            },
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 8
