          "intervalFactor": 1,
          "legendFormat": "{{phase}}: {{$grouping}}",
          "refId": "A"
        }
      ],
      "title": "Sync Failures",
      "type": "timeseries",
      "description": "Sincronizaciones con phase Error o Failed. Un valor mayor a 0 indica fallos reales de aplicacion, permisos, manifests invalidos o conectividad."
