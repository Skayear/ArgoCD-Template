          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Aplicaciones OutOfSync",
      "type": "table"
    },
    {
      "datasource": {
        "uid": "$datasource"
      },
      "description": "Ranking de aplicaciones con mas fallos de sync en 24h. Ideal para priorizar investigacion.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "id": 9103,
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "uid": "$datasource"
          },
          "expr": "topk(10, sum(round(increase(argocd_app_sync_total{namespace=~\"$namespace\",dest_server=~\"$cluster\",phase=~\"Error|Failed\"}[24h]))) by (project, name, exported_namespace, phase))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Top apps con fallos de sync (24h)",
      "type": "table"
    }
