  "description": "Resumen compacto para revisar estado, capacidad, distribución y señales críticas de Karpenter.\nDashboards curados con información operacional detallada en cada panel.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
