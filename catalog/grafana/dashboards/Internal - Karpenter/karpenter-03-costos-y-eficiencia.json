    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Qué mide:\n- Comparación mensual entre el baseline anterior y el costo actual estimado.\n\nBaseline:\n- 5 nodos m7i.xlarge durante 730 horas.\n\nActual:\n- Suma de node_total_hourly_cost multiplicada por 730.\n\nLectura rápida:\n- Si la barra actual es menor que baseline, Karpenter está reduciendo costo mensual estimado.",
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 15,
        "x": 0,
        "y": 1
      },
      "id": 2,
