          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "730 * 5 * (avg(node_total_hourly_cost{instance_type=\"m7i.xlarge\"}) or vector(0.20159656163787842))",
