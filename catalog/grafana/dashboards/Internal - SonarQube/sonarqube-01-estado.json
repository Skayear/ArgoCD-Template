{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations y Alertas",
        "type": "dashboard"
      }
    ]
  },
  "description": "SonarQube: estado general del servicio y su base de datos. Dashboard pensado para validar rapidamente si la plataforma esta sana para uso normal.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Estado de disponibilidad del servicio SonarQube (segun metrica up del job seleccionado).\n\nUso operacional:\n- Si marca 1, el endpoint monitoreado responde.\n- Si marca 0, revisar pod/deployment/service y conectividad de red.\n- Este panel responde 'esta vivo o no', no reemplaza chequeos funcionales de login o analisis.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "Caido"
                },
                "1": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "max(up{job=~\"$job_sonar\"})",
          "refId": "A"
        }
      ],
      "title": "SonarQube disponible",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Estado de conectividad a PostgreSQL desde el exporter (pg_up).\n\nUso operacional:\n- Si este panel cae a 0, SonarQube puede fallar en login, lectura de proyectos o persistencia.\n- Primer paso en incidentes donde SonarQube responde lento o con errores 5xx.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "Sin conexion"
                },
                "1": {
                  "text": "OK"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "max(pg_up{job=~\"$job_db\"})",
          "refId": "A"
        }
      ],
      "title": "PostgreSQL disponible",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cantidad total de conexiones activas en la base de datos de SonarQube.\n\nUso operacional:\n- Ayuda a detectar saturacion de conexiones antes de errores visibles.\n- Si crece sostenidamente cerca del limite, revisar pool de conexiones y carga de scans/usuarios.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "sum(pg_stat_database_numbackends{job=~\"$job_db\", datname=~\"$database\"})",
          "refId": "A"
        }
      ],
      "title": "Conexiones activas DB",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Ultimo estado de error de scrape del postgres-exporter.\n\nUso operacional:\n- 0 indica scrape exitoso.\n- 1 indica error al recolectar metricas (usuario/permisos/red/timeout).\n- Si queda en 1, el resto de paneles DB puede volverse engañoso.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "OK"
                },
                "1": {
                  "text": "Error scrape"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "max(pg_exporter_last_scrape_error{job=~\"$job_db\"})",
          "refId": "A"
        }
      ],
      "title": "Estado scrape exporter",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Tamano de la base de datos de SonarQube.\n\nUso operacional:\n- Tendencia de crecimiento para planificar capacidad y costos.\n- Saltos bruscos pueden indicar cambios de retencion o carga anormal de analisis.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=~\"$job_db\", datname=~\"$database\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "title": "Tamano de base de datos",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Transacciones commit y rollback por segundo.\n\nUso operacional:\n- Commit alto + rollback bajo suele ser comportamiento sano.\n- Suba de rollbacks puede indicar errores de aplicacion o problemas transaccionales en DB.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{job=~\"$job_db\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "{{datname}} commit/s",
          "refId": "A"
        },
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{job=~\"$job_db\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "{{datname}} rollback/s",
          "refId": "B"
        }
      ],
      "title": "Transacciones commit/rollback",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "sonarqube",
    "estado"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Internal Mimir",
          "value": "Internal Mimir"
        },
        "includeAll": false,
        "label": "Metrica",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(up{job=~\".*sonarqube.*\"}, job)",
        "includeAll": true,
        "label": "Job Sonar",
        "multi": true,
        "name": "job_sonar",
        "options": [],
        "query": {
          "query": "label_values(up{job=~\".*sonarqube.*\"}, job)",
          "refId": "A"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(pg_up{job=~\".*sonarqube.*postgres.*\"}, job)",
        "includeAll": true,
        "label": "Job PostgreSQL exporter",
        "multi": true,
        "name": "job_db",
        "options": [],
        "query": {
          "query": "label_values(pg_up{job=~\".*sonarqube.*postgres.*\"}, job)",
          "refId": "A"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(pg_stat_database_numbackends{job=~\"$job_db\"}, datname)",
        "includeAll": true,
        "label": "Base de datos",
        "multi": true,
        "name": "database",
        "options": [],
        "query": {
          "query": "label_values(pg_stat_database_numbackends{job=~\"$job_db\"}, datname)",
          "refId": "A"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "SonarQube / Estado General",
  "uid": "platform-sonarqube-estado",
  "version": 1,
  "weekStart": ""
}
