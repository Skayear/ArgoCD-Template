      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "kube_pod_status_ready{namespace=\"sonarqube\",pod=\"sonarqube-0\",condition=\"true\"}",
          "instant": true,
          "legendFormat": "pod_ready",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"sonarqube\",pod=\"sonarqube-0\"})",
          "instant": true,
          "legendFormat": "restarts",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[5m]) * on(instance) group_left() label_replace(kube_pod_info{namespace=\"sonarqube\",pod=\"sonarqube-0\"},\"instance\",\"$1:9100\",\"host_ip\",\"(.*)\")) * 100)",
          "instant": true,
          "legendFormat": "cpu_pct",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "(1 - (sum(node_memory_MemAvailable_bytes{job=\"node-exporter\"} * on(instance) group_left() label_replace(kube_pod_info{namespace=\"sonarqube\",pod=\"sonarqube-0\"},\"instance\",\"$1:9100\",\"host_ip\",\"(.*)\")) / sum(node_memory_MemTotal_bytes{job=\"node-exporter\"} * on(instance) group_left() label_replace(kube_pod_info{namespace=\"sonarqube\",pod=\"sonarqube-0\"},\"instance\",\"$1:9100\",\"host_ip\",\"(.*)\")))) * 100",
          "instant": true,
          "legendFormat": "mem_pct",
          "range": false,
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "(1 - (sum(node_filesystem_avail_bytes{job=\"node-exporter\",fstype!=\"tmpfs\",mountpoint=\"/\"} * on(instance) group_left() label_replace(kube_pod_info{namespace=\"sonarqube\",pod=\"sonarqube-0\"},\"instance\",\"$1:9100\",\"host_ip\",\"(.*)\")) / sum(node_filesystem_size_bytes{job=\"node-exporter\",fstype!=\"tmpfs\",mountpoint=\"/\"} * on(instance) group_left() label_replace(kube_pod_info{namespace=\"sonarqube\",pod=\"sonarqube-0\"},\"instance\",\"$1:9100\",\"host_ip\",\"(.*)\")))) * 100",
          "instant": true,
          "legendFormat": "disk_pct",
          "range": false,
          "refId": "E"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"node-exporter\",device!=\"lo\"}[5m]) * on(instance) group_left() label_replace(kube_pod_info{namespace=\"sonarqube\",pod=\"sonarqube-0\"},\"instance\",\"$1:9100\",\"host_ip\",\"(.*)\"))",
          "instant": true,
          "legendFormat": "net_rx",
          "range": false,
          "refId": "F"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
