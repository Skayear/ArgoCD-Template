{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations y Alertas",
        "type": "dashboard"
      }
    ]
  },
  "description": "SonarQube: vista Canvas con metricas de infraestructura del nodo (node-exporter) y estado del pod (kube-state-metrics). Unico panel tipo Canvas con layout de diagrama.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Canvas de monitoreo de SonarQube. Muestra estado del pod y metricas del nodo donde corre sonarqube-0. Las queries de node-exporter usan un join dinamico con kube_pod_info para seguir al pod si cambia de nodo.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pod_ready" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",   "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": { "color": "red",   "index": 0, "text": "DOWN" },
                      "1": { "color": "green", "index": 1, "text": "UP"   }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "restarts" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 1    },
                    { "color": "red",    "value": 5    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "cpu_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 60   },
                    { "color": "red",    "value": 80   }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "mem_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 70   },
                    { "color": "red",    "value": 85   }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "disk_pct" },
            "properties": [
              { "id": "unit", "value": "percent" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green",  "value": null },
                    { "color": "yellow", "value": 70   },
                    { "color": "red",    "value": 85   }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "net_rx" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "color", "value": { "fixed": "#3d85c8", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "net_tx" },
            "properties": [
              { "id": "unit", "value": "Bps" },
              { "id": "color", "value": { "fixed": "#3d85c8", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "load1" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "color", "value": { "fixed": "#f0a500", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "load5" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "color", "value": { "fixed": "#f0a500", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "load15" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "color", "value": { "fixed": "#f0a500", "mode": "fixed" } }
            ]
          }
        ]
      },
