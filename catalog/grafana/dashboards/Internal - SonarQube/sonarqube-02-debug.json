{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations y Alertas",
        "type": "dashboard"
      }
    ]
  },
  "description": "SonarQube: modo debug enfocado en DB/exporter para investigar degradaciones, lock contention y problemas de scraping.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Duracion maxima de transaccion activa.\n\nUso operacional:\n- Si crece de forma sostenida, puede haber transacciones colgadas bloqueando otras operaciones.\n- Panel clave cuando SonarQube se percibe lento en UI, análisis o background tasks.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "max by (datname) (pg_stat_activity_max_tx_duration{job=~\"$job_db\", datname=~\"$database\"})",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "title": "Transaccion mas larga",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cantidad de locks actuales.\n\nUso operacional:\n- Subas abruptas o valores altos sostenidos pueden implicar contencion.\n- Util para correlacionar con timeouts, lentitud y rollbacks.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (datname, mode) (pg_locks_count{job=~\"$job_db\", datname=~\"$database\"})",
          "legendFormat": "{{datname}} {{mode}}",
          "refId": "A"
        }
      ],
      "title": "Locks por modo",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Duracion de collectors del postgres-exporter.\n\nUso operacional:\n- Muestra que collector esta costando mas tiempo.\n- Si algun collector se vuelve lento, puede impactar scrape duration y calidad de observabilidad.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "max by (collector) (pg_scrape_collector_duration_seconds{job=~\"$job_db\"})",
          "legendFormat": "{{collector}}",
          "refId": "A"
        }
      ],
      "title": "Duracion por collector",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Estado de exito/falla por collector del exporter.\n\nUso operacional:\n- 1 = exito, 0 = falla.\n- Si un collector falla de forma intermitente, los paneles que dependen de ese collector pueden mostrar vacios o datos obsoletos.",
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "min by (collector) (pg_scrape_collector_success{job=~\"$job_db\"})",
          "legendFormat": "{{collector}}",
          "refId": "A"
        }
      ],
      "title": "Exito de collectors",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Rollbacks por segundo.\n\nUso operacional:\n- Aumentos de rollback/s indican fallas transaccionales o conflictos.\n- Correlacionar con errores de aplicacion y locks para localizar causa raiz.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{job=~\"$job_db\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "title": "Rollbacks por segundo",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Deadlocks detectados por segundo.\n\nUso operacional:\n- Deadlocks sostenidos indican contencion real y riesgo de impacto funcional.\n- Si no es cero de forma repetida, revisar patrones de concurrencia y queries involucradas.",
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (datname) (rate(pg_stat_database_deadlocks{job=~\"$job_db\", datname=~\"$database\"}[$__rate_interval]))",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "title": "Deadlocks por segundo",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "sonarqube",
    "debug"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Internal Mimir",
          "value": "Internal Mimir"
        },
        "includeAll": false,
        "label": "Metrica",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(pg_up{job=~\".*sonarqube.*postgres.*\"}, job)",
        "includeAll": true,
        "label": "Job PostgreSQL exporter",
        "multi": true,
        "name": "job_db",
        "options": [],
        "query": {
          "query": "label_values(pg_up{job=~\".*sonarqube.*postgres.*\"}, job)",
          "refId": "A"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(pg_stat_database_numbackends{job=~\"$job_db\"}, datname)",
        "includeAll": true,
        "label": "Base de datos",
        "multi": true,
        "name": "database",
        "options": [],
        "query": {
          "query": "label_values(pg_stat_database_numbackends{job=~\"$job_db\"}, datname)",
          "refId": "A"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "SonarQube / Debug",
  "uid": "platform-sonarqube-debug",
  "version": 1,
  "weekStart": ""
}
